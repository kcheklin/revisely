<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEECE1"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:background="@drawable/rounded_background"
        android:padding="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password ?"
            android:textSize="28sp"
            android:textColor="#3D2B1F"
            android:textStyle="bold"
            android:shadowColor="#2D1E14"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="2"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your email and we'll send you a reset link"
            android:textSize="14sp"
            android:textColor="#7C6B5C"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email address"
            android:textSize="16sp"
            android:textColor="#3D2B1F"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="example@gmail.com"
            android:paddingLeft="20dp"
            android:drawableLeft="@android:drawable/ic_dialog_email"
            android:drawablePadding="10dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnSendResetLink"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="Send Reset Link"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_background"
            android:layout_gravity="center"
            android:textSize="18sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back To Login"
            android:textColor="#A08F82"
            android:layout_gravity="center"
            android:clickable="true"/>

    </LinearLayout>

    <!-- Success Dialog -->
    <LinearLayout
        android:id="@+id/successDialog"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="horizontal"
        android:background="@drawable/success_dialog_background"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✓"
            android:textSize="30sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/success_icon_background"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Successfully Sent !"
            android:textSize="18sp"
            android:textColor="#3D3228"
            android:layout_marginLeft="15dp"/>

    </LinearLayout>

</RelativeLayout>