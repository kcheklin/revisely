<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#EEECE1"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:background="@drawable/rounded_background"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textSize="30sp"
                android:textColor="#3D2B1F"
                android:textStyle="bold"
                android:shadowColor="#2D1E14"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="2"
                android:layout_gravity="center"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Our Learning Community"
                android:textSize="14sp"
                android:textColor="#7C6B5C"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="16sp"
                android:textColor="#3D2B1F"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Enter Your Full Name"
                android:paddingLeft="20dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="16sp"
                android:textColor="#3D2B1F"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Enter Your Email"
                android:inputType="textEmailAddress"
                android:paddingLeft="20dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="16sp"
                android:textColor="#3D2B1F"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Create A Password"
                android:inputType="textPassword"
                android:paddingLeft="20dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Password"
                android:textSize="16sp"
                android:textColor="#3D2B1F"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Confirm Your Password"
                android:inputType="textPassword"
                android:paddingLeft="20dp"
                android:background="@drawable/edittext_background"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I Am A ..."
                android:textSize="16sp"
                android:textColor="#3D2B1F"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="30dp">

                <Button
                    android:id="@+id/btnPrimaryStudent"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Primary\nStudent"
                    android:textColor="#3D2B1F"
                    android:background="@drawable/btn_unselected"
                    app:backgroundTint="@null"
                    android:layout_marginRight="10dp"/>

                <Button
                    android:id="@+id/btnSecondaryStudent"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Secondary\nStudent"
                    android:textColor="#3D2B1F"
                    android:background="@drawable/btn_unselected"
                    app:backgroundTint="@null"
                    android:layout_marginLeft="10dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="Sign Up"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_background"
                app:backgroundTint="@null"
                android:layout_gravity="center"
                android:textSize="18sp"/>

        </LinearLayout>

        <!-- Success Dialog -->
        <LinearLayout
            android:id="@+id/successDialog"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:background="@drawable/success_dialog_background"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✓"
                android:textSize="30sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/success_icon_background"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done Sign Up !"
                android:textSize="18sp"
                android:textColor="#3D3228"
                android:layout_marginLeft="15dp"/>

        </LinearLayout>

    </RelativeLayout>

</ScrollView>