<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:id="@+id/CVReview"
    app:cardCornerRadius="14dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <ImageView
            android:id="@+id/IVAvatarStudentReview"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_avatar"
            android:outlineProvider="background"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/TVStudentNameReview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="4dp"
            android:text="Student Name"
            android:textColor="#1E2939"
            app:layout_constraintStart_toEndOf="@+id/IVAvatarStudentReview"
            app:layout_constraintTop_toTopOf="@+id/IVAvatarStudentReview" />

        <ImageView
            android:id="@+id/IVRatingReview2"
            android:layout_width="74dp"
            android:layout_height="11dp"
            android:layout_marginTop="5dp"
            app:layout_constraintStart_toStartOf="@+id/TVStudentNameReview"
            app:layout_constraintTop_toBottomOf="@+id/TVStudentNameReview"
            app:srcCompat="@drawable/ic_rating_5" />

        <TextView
            android:id="@+id/TVRatingStudentReview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4A5565"
            android:text="Student rating"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@id/IVAvatarStudentReview"
            app:layout_constraintTop_toBottomOf="@id/IVAvatarStudentReview"/>

        <ImageView
            android:id="@+id/imageView10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@+id/TVRatingStudentReview"
            app:layout_constraintTop_toBottomOf="@+id/TVRatingStudentReview"
            app:srcCompat="@drawable/ic_like" />

        <TextView
            android:id="@+id/TVLikes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Helpful"
            android:textColor="#6A7282"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@+id/imageView10"
            app:layout_constraintTop_toTopOf="@+id/imageView10" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
