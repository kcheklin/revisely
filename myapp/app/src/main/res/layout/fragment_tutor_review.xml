<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEECE1">

    <ImageView
        android:id="@+id/IVBackReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_left" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="100dp"
        android:text="@string/text_rating_reviews"
        android:textSize="18sp"
        app:layout_constraintStart_toEndOf="@id/IVBackReview"
        app:layout_constraintTop_toTopOf="@+id/IVBackReview" />

    <ImageView
        android:id="@+id/IVAvatarReview"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="25dp"
        android:background="@drawable/bg_avatar"
        android:outlineProvider="background"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/IVBackReview" />

    <TextView
        android:id="@+id/TVTutorNameReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="4dp"
        android:text="Tutor Name"
        android:textColor="#1E2939"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/IVAvatarReview"
        app:layout_constraintTop_toTopOf="@+id/IVAvatarReview" />

    <TextView
        android:id="@+id/TVTutorRoleReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Tutor Role"
        android:textColor="#4A5565"
        app:layout_constraintStart_toStartOf="@+id/TVTutorNameReview"
        app:layout_constraintTop_toBottomOf="@+id/TVTutorNameReview" />

    <androidx.cardview.widget.CardView
        android:id="@+id/CVRatingReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="14dp"
        app:layout_constraintStart_toStartOf="@+id/IVAvatarReview"
        app:layout_constraintTop_toBottomOf="@id/IVAvatarReview">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">

            <TextView
                android:id="@+id/TVRatingReview"
                android:layout_width="91dp"
                android:layout_height="37dp"
                android:layout_marginStart="16dp"
                android:gravity="center"
                android:text="Rating"
                android:textColor="#1E2939"
                android:textSize="35sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/IVRatingReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/TVRatingReview"
                app:srcCompat="@drawable/ic_rating_5" />

            <TextView
                android:id="@+id/TVReviews2"
                android:layout_width="90dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="reviews"
                android:textColor="#6A7282"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@+id/IVRatingReview"
                app:layout_constraintTop_toBottomOf="@+id/IVRatingReview" />

            <TextView
                android:id="@+id/textView15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:text="5"
                android:textSize="11sp"
                android:textColor="#4A5565"
                app:layout_constraintStart_toEndOf="@+id/TVRatingReview"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textView16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="4"
                android:textSize="11sp"
                android:textColor="#4A5565"
                app:layout_constraintStart_toStartOf="@+id/textView15"
                app:layout_constraintTop_toBottomOf="@+id/textView15" />

            <TextView
                android:id="@+id/textView17"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="3"
                android:textSize="11sp"
                android:textColor="#4A5565"
                app:layout_constraintStart_toStartOf="@+id/textView15"
                app:layout_constraintTop_toBottomOf="@+id/textView16" />

            <TextView
                android:id="@+id/textView18"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="2"
                android:textSize="11sp"
                android:textColor="#4A5565"
                app:layout_constraintStart_toStartOf="@+id/textView15"
                app:layout_constraintTop_toBottomOf="@+id/textView17" />

            <TextView
                android:id="@+id/textView19"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="1"
                android:textSize="11sp"
                android:textColor="#4A5565"
                app:layout_constraintStart_toStartOf="@+id/textView15"
                app:layout_constraintTop_toBottomOf="@+id/textView18" />

            <ProgressBar
                android:id="@+id/PB5StarReview"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="111dp"
                android:layout_height="14dp"
                android:layout_marginStart="15dp"
                app:layout_constraintStart_toEndOf="@+id/imageView3"
                app:layout_constraintTop_toTopOf="@+id/textView15" />

            <ProgressBar
                android:id="@+id/PB4StarReview"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="112dp"
                android:layout_height="12dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@+id/PB5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/PB5StarReview" />

            <ProgressBar
                android:id="@+id/PB3StarReview"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="111dp"
                android:layout_height="14dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@+id/PB5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/PB4StarReview" />

            <ProgressBar
                android:id="@+id/PB2StarReview"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="111dp"
                android:layout_height="14dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@+id/PB5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/PB3StarReview" />

            <ProgressBar
                android:id="@+id/PB1StarReview"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="111dp"
                android:layout_height="14dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@+id/PB5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/PB2StarReview" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@+id/textView15"
                app:layout_constraintTop_toTopOf="@+id/textView15"
                app:srcCompat="@drawable/ic_star" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/imageView3"
                app:layout_constraintTop_toBottomOf="@+id/imageView3"
                app:srcCompat="@drawable/ic_star" />

            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/imageView4"
                app:layout_constraintTop_toBottomOf="@+id/imageView4"
                app:srcCompat="@drawable/ic_star" />

            <ImageView
                android:id="@+id/imageView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/imageView5"
                app:layout_constraintTop_toBottomOf="@+id/imageView5"
                app:srcCompat="@drawable/ic_star" />

            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/imageView6"
                app:layout_constraintTop_toBottomOf="@+id/imageView6"
                app:srcCompat="@drawable/ic_star" />

            <TextView
                android:id="@+id/TV5StarReview"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="5"
                android:textColor="#6A7282"
                android:textSize="11sp"
                android:gravity="end"
                app:layout_constraintStart_toEndOf="@+id/PB5StarReview"
                app:layout_constraintTop_toTopOf="@+id/textView15" />

            <TextView
                android:id="@+id/TV4StarReview"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="4"
                android:textColor="#6A7282"
                android:textSize="11sp"
                android:gravity="end"
                app:layout_constraintStart_toStartOf="@+id/TV5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/TV5StarReview" />

            <TextView
                android:id="@+id/TV3StarReview"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="3"
                android:textColor="#6A7282"
                android:textSize="11sp"
                android:gravity="end"
                app:layout_constraintStart_toStartOf="@+id/TV5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/TV4StarReview" />

            <TextView
                android:id="@+id/TV2StarReview"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:text="2"
                android:textColor="#6A7282"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@+id/TV5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/TV3StarReview" />

            <TextView
                android:id="@+id/TV1StarReview"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="1"
                android:textColor="#6A7282"
                android:textSize="11sp"
                android:gravity="end"
                app:layout_constraintStart_toStartOf="@+id/TV5StarReview"
                app:layout_constraintTop_toBottomOf="@+id/TV2StarReview" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/TVFilterReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="15dp"
        android:text="@string/text_filter_rating"
        android:textColor="#6A7282"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/CVRatingReview" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/TVFilterReview"
        android:id="@+id/HSVReview">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" >

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/CGReviewRating"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/CPAllReview"
                    style="@style/ChipRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="All" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CP5StarsReview"
                    style="@style/ChipRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="5" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CP4StarsReview"
                    style="@style/ChipRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CP3StarsReview"
                    style="@style/ChipRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CP2StarsReview"
                    style="@style/ChipRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CP1StarsReview"
                    style="@style/ChipRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1" />

            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/TVStudentReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_student_review"
        android:layout_marginStart="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/HSVReview"
        android:textColor="#1E2939"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/RVReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintStart_toStartOf="@id/TVStudentReview"
        app:layout_constraintTop_toBottomOf="@id/TVStudentReview"/>
</androidx.constraintlayout.widget.ConstraintLayout>
